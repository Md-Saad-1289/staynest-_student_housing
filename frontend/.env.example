# ============================================
# Frontend Environment Configuration
# ============================================
# SECURITY WARNING: This is a template file.
# Create a .env.local file with actual values - NEVER commit .env.local to git
# Use: cp .env.example .env.local

# ============================================
# API Configuration
# ============================================
# Backend API URL - the base URL of your backend server
# Local development: http://localhost:5000
# Production: https://your-api-domain.com (without /api/v1)
# The frontend will automatically append /api/v1 to create the full API endpoint
REACT_APP_API_URL=http://localhost:5000

# ============================================
# Application Configuration
# ============================================
# Application name
REACT_APP_NAME=nestforstay

# Environment flag for debugging
REACT_APP_DEBUG=false

# ============================================
# Feature Flags
# ============================================
# Enable React DevTools in production (not recommended)
REACT_APP_ENABLE_DEVTOOLS=false
