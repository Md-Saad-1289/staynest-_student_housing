# ============================================
# Backend Environment Configuration
# ============================================
# SECURITY WARNING: This is a template file.
# Create a .env file with actual values - NEVER commit .env to git
# Use: cp .env.example .env

# ============================================
# Database Configuration
# ============================================
# MongoDB Atlas connection URI
# Format: mongodb+srv://username:password@cluster.mongodb.net/database_name?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://your_username:your_password@cluster.mongodb.net/staynest?retryWrites=true&w=majority

# ============================================
# Server Configuration
# ============================================
PORT=5000
NODE_ENV=production

# ============================================
# Security & Authentication
# ============================================
# JWT Secret - Generate a strong random string
# Command: openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_generate_strong_random_string
JWT_EXPIRE=7d

# ============================================
# CORS Configuration
# ============================================
# Frontend URLs allowed to make requests to this backend
FRONTEND_URL_PROD=https://yourdomain.com
FRONTEND_URL_DEV=http://localhost:3000
FRONTEND_URL_EXTRA=https://www.yourdomain.com

# ============================================
# Admin Account Setup (Optional)
# ============================================
# These credentials are used to create an admin account on first startup
# Only set if you want automatic admin user creation
ADMIN_EMAIL=admin@staynest.local
ADMIN_PASSWORD=change_to_strong_password
ADMIN_SECRET=admin_secret_key_for_registration
